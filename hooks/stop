#!/usr/bin/env bash
set -euo pipefail

# Read the Stop hook payload from stdin
INPUT=$(cat)

# Guard: prevent infinite loop if hook already fired this continuation
STOP_HOOK_ACTIVE=$(echo "$INPUT" | jq -r '.stop_hook_active')
if [ "$STOP_HOOK_ACTIVE" = "true" ]; then
  exit 0
fi

# Get transcript path and expand leading ~
TRANSCRIPT_PATH=$(echo "$INPUT" | jq -r '.transcript_path')
TRANSCRIPT_PATH="${TRANSCRIPT_PATH/#\~/$HOME}"

if [ ! -f "$TRANSCRIPT_PATH" ]; then
  exit 0
fi

# Check whether HEAD has changed since the last user prompt
CWD=$(echo "$INPUT" | jq -r '.cwd // empty')
if [ -z "$CWD" ]; then
  CWD=$(pwd)
fi
KEY=$(echo -n "$CWD" | shasum | cut -c1-16)
HASH_FILE="/tmp/code-quiz-head-${KEY}"
DIFF_FILE="/tmp/code-quiz-diff-${KEY}"

CURRENT_HEAD=$(git -C "$CWD" rev-parse HEAD 2>/dev/null || echo "")
if [ -z "$CURRENT_HEAD" ]; then
  exit 0
fi

HEAD_CHANGED=false
SAVED_HEAD=""
if [ -f "$HASH_FILE" ]; then
  SAVED_HEAD=$(cat "$HASH_FILE")
  if [ -n "$SAVED_HEAD" ] && [ "$SAVED_HEAD" != "$CURRENT_HEAD" ]; then
    # Verify saved hash still exists in repo (handles force pushes etc.)
    if git -C "$CWD" cat-file -e "${SAVED_HEAD}^{commit}" 2>/dev/null; then
      HEAD_CHANGED=true
    fi
  fi
fi

# Build the diff
DOC_EXCLUDES=(':!*.md' ':!*.txt' ':!*.rst')

# If HEAD hasn't changed, check for uncommitted changes (staged or untracked non-doc files).
# If HEAD changed, new commits prove code was written — skip this guard.
if [ "$HEAD_CHANGED" != "true" ]; then
  UNCOMMITTED_COUNT=$(git -C "$CWD" diff HEAD -- "${DOC_EXCLUDES[@]}" 2>/dev/null | wc -l | tr -d ' ')
  if [ "$UNCOMMITTED_COUNT" -eq 0 ]; then
    while IFS= read -r f; do
      [[ "$f" =~ \.(md|txt|rst)$ ]] && continue
      UNCOMMITTED_COUNT=$((UNCOMMITTED_COUNT + 1))
    done < <(git -C "$CWD" ls-files --others --exclude-standard 2>/dev/null || true)
  fi
  if [ "$UNCOMMITTED_COUNT" -eq 0 ]; then
    exit 0
  fi
fi

if [ "$HEAD_CHANGED" = "true" ]; then
  COMMITTED_DIFF=$(git -C "$CWD" diff "${SAVED_HEAD}..${CURRENT_HEAD}" -- "${DOC_EXCLUDES[@]}" 2>/dev/null || echo "")
  UNCOMMITTED_DIFF=$(git -C "$CWD" diff HEAD -- "${DOC_EXCLUDES[@]}" 2>/dev/null || echo "")

  if [ -n "$COMMITTED_DIFF" ] && [ -n "$UNCOMMITTED_DIFF" ]; then
    DIFF="${COMMITTED_DIFF}
${UNCOMMITTED_DIFF}"
  elif [ -n "$COMMITTED_DIFF" ]; then
    DIFF="$COMMITTED_DIFF"
  else
    DIFF="$UNCOMMITTED_DIFF"
  fi
else
  DIFF=$(git -C "$CWD" diff HEAD -- "${DOC_EXCLUDES[@]}" 2>/dev/null || echo "")
  # Also capture newly-created untracked files (Write tool creates these)
  while IFS= read -r f; do
    [[ "$f" =~ \.(md|txt|rst)$ ]] && continue
    DIFF+=$(git -C "$CWD" diff --no-index /dev/null "$CWD/$f" 2>/dev/null || true)
  done < <(git -C "$CWD" ls-files --others --exclude-standard 2>/dev/null || true)
fi

if [ -z "$DIFF" ]; then
  exit 0
fi

# Count only +/- lines (excluding file header lines like +++ and ---)
CHANGED_LINE_COUNT=$(echo "$DIFF" | grep -E '^[+-]' | grep -cvE '^(\+\+\+|---)' || echo "0")

TRUNCATION_NOTICE=""
if [ "$CHANGED_LINE_COUNT" -gt 500 ]; then
  # Keep only the first 500 changed lines using awk
  DIFF=$(echo "$DIFF" | awk '
    /^[+-]/ && !/^(\+\+\+|---)/ { count++ }
    count <= 500 { print }
  ')
  TRUNCATION_NOTICE="
[diff truncated at 500 changed lines — quiz covers visible changes only]"
fi

# Write diff to temp file so it doesn't flood the terminal
echo "$DIFF" > "$DIFF_FILE"

# Build the reason string and output decision:block.
# jq handles all JSON escaping via --arg.
REASON="Quiz triggered — ${CHANGED_LINE_COUNT} changed line(s). Please run the /quiz skill now.

Diff saved to: ${DIFF_FILE}${TRUNCATION_NOTICE}

Do not run git diff — read the diff from the file path above."

jq -n --arg reason "$REASON" '{"decision": "block", "reason": $reason}'
