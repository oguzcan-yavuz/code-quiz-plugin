#!/usr/bin/env bash
set -euo pipefail

# Read the Stop hook payload from stdin
INPUT=$(cat)

# Guard: prevent infinite loop if hook already fired this continuation
STOP_HOOK_ACTIVE=$(echo "$INPUT" | jq -r '.stop_hook_active')
if [ "$STOP_HOOK_ACTIVE" = "true" ]; then
  exit 0
fi

# Get transcript path and expand leading ~
TRANSCRIPT_PATH=$(echo "$INPUT" | jq -r '.transcript_path')
TRANSCRIPT_PATH="${TRANSCRIPT_PATH/#\~/$HOME}"

if [ ! -f "$TRANSCRIPT_PATH" ]; then
  exit 0
fi

# Check whether HEAD has changed since the last user prompt
CWD=$(pwd)
KEY=$(echo -n "$CWD" | shasum | cut -c1-16)
HASH_FILE="/tmp/code-quiz-head-${KEY}"

CURRENT_HEAD=$(git rev-parse HEAD 2>/dev/null || echo "")
if [ -z "$CURRENT_HEAD" ]; then
  exit 0
fi

HEAD_CHANGED=false
SAVED_HEAD=""
if [ -f "$HASH_FILE" ]; then
  SAVED_HEAD=$(cat "$HASH_FILE")
  if [ -n "$SAVED_HEAD" ] && [ "$SAVED_HEAD" != "$CURRENT_HEAD" ]; then
    # Verify saved hash still exists in repo (handles force pushes etc.)
    if git cat-file -e "${SAVED_HEAD}^{commit}" 2>/dev/null; then
      HEAD_CHANGED=true
    fi
  fi
fi

# Edit/Write guard: only needed when HEAD didn't change (direct edits in this session).
# If HEAD changed, new commits prove code was written (possibly by subagents).
if [ "$HEAD_CHANGED" != "true" ]; then
  HAS_CODE_EDIT=$(jq -rsc '
    [ .[] | select(.role == "assistant") ] | last // {} |
    .content // [] |
    map(select(.type == "tool_use" and (.name == "Edit" or .name == "Write"))) |
    length > 0
  ' "$TRANSCRIPT_PATH" 2>/dev/null || echo "false")

  if [ "$HAS_CODE_EDIT" != "true" ]; then
    exit 0
  fi
fi

# Build the diff
DOC_EXCLUDES=(':!*.md' ':!*.txt' ':!*.rst')

if [ "$HEAD_CHANGED" = "true" ]; then
  COMMITTED_DIFF=$(git diff "${SAVED_HEAD}..${CURRENT_HEAD}" -- "${DOC_EXCLUDES[@]}" 2>/dev/null || echo "")
  UNCOMMITTED_DIFF=$(git diff HEAD -- "${DOC_EXCLUDES[@]}" 2>/dev/null || echo "")

  if [ -n "$COMMITTED_DIFF" ] && [ -n "$UNCOMMITTED_DIFF" ]; then
    DIFF="${COMMITTED_DIFF}
${UNCOMMITTED_DIFF}"
  elif [ -n "$COMMITTED_DIFF" ]; then
    DIFF="$COMMITTED_DIFF"
  else
    DIFF="$UNCOMMITTED_DIFF"
  fi
else
  DIFF=$(git diff HEAD -- "${DOC_EXCLUDES[@]}" 2>/dev/null || echo "")
fi

if [ -z "$DIFF" ]; then
  exit 0
fi

# Count only +/- lines (excluding file header lines like +++ and ---)
CHANGED_LINE_COUNT=$(echo "$DIFF" | grep -E '^[+-]' | grep -cvE '^(\+\+\+|---)' || echo "0")

TRUNCATION_NOTICE=""
if [ "$CHANGED_LINE_COUNT" -gt 500 ]; then
  # Keep only the first 500 changed lines using awk
  DIFF=$(echo "$DIFF" | awk '
    /^[+-]/ && !/^(\+\+\+|---)/ { count++ }
    count <= 500 { print }
  ')
  TRUNCATION_NOTICE="
[diff truncated at 500 changed lines — quiz covers visible changes only]"
fi

# Build the reason string and output decision:block.
# jq handles all JSON escaping via --arg.
REASON="Please run the /quiz skill now. The diff is pre-supplied below — do not run git diff again.

DIFF:
---
${DIFF}${TRUNCATION_NOTICE}"

jq -n --arg reason "$REASON" '{"decision": "block", "reason": $reason}'
